{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const r=process.env.PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT;if(r)require(r+'/scripts/yt-loop.js').main(['hook-prompt-submit'])\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const r=process.env.PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT;if(r)require(r+'/scripts/yt-loop.js').main(['hook-stop'])\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
